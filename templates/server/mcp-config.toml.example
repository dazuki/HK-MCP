# Server-specifik konfiguration. Kopiera till `mcp-config.toml` i samma
# katalog och anpassa. Värden här överskriver ../../settings.toml i
# monorepo-roten. HK_*-miljövariabler och CLI-argument överskriver i sin tur.

# Transport: "stdio" | "sse" | "streamable-http"
transport = "streamable-http"

# Port för HTTP-transporter
port = 8000

# Tillåtna Host-headers (MCP blockerar andra mot DNS rebinding).
# Lägg till proxy-domän och/eller LAN-IP här. "*" = alla.
allowed_hosts = ["example.mcp.local", "192.168.0.1"]

# Tillåtna Origin-headers (för webbaserade MCP-klienter).
# Sätt klientens domän här. "*" = alla.
allowed_origins = ["https://mcp.klient.se"]

# Betrodda proxy-IP:n för X-Forwarded-*-headers. Använd proxyns IP.
forwarded_allow_ips = "192.168.0.1"

# Logga HTTP-förfrågningar (uvicorn access log). false = tyst, true = utförlig.
access_log = false
