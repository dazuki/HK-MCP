# Kopiera till .env. Gitignorerad.

GHCR_OWNER=din-github-user
IMAGE_TAG=latest

# Bearer-tokens (JSON-array). Generera: openssl rand -hex 32
SKOLVERKET_AUTH_TOKENS=["byt-ut"]
KOLADA_AUTH_TOKENS=["byt-ut"]
TIME_AUTH_TOKENS=["byt-ut"]
SCB_AUTH_TOKENS=["byt-ut"]

# Valfritt - har rimliga defaults i docker-compose.prod.yml.

# Domäner din reverse proxy använder (DNS rebinding-skydd). JSON-array.
# HK_ALLOWED_HOSTS=["mcp.example.org"]

# IP/subnät för reverse proxy som skickar X-Forwarded-*-headers.
# 172.16.0.0/12 täcker default docker bridge-nät. Justera vid extern proxy.
# HK_FORWARDED_ALLOW_IPS=172.16.0.0/12

# Tillåtna CORS-origins per server (JSON-array). Default: ["*"] (alla).
# Sätt till din klients domän vid publik exponering.
# SKOLVERKET_ALLOWED_ORIGINS=["https://min-app.example.org"]
# KOLADA_ALLOWED_ORIGINS=["https://min-app.example.org"]
# TIME_ALLOWED_ORIGINS=["https://min-app.example.org"]
# SCB_ALLOWED_ORIGINS=["https://min-app.example.org"]
